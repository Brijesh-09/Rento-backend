# Node modules
node_modules/

# Build output
dist/
build/
out/

# TypeScript
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# Cache
.cache/
.parcel-cache/
.eslintcache
.npm

# Misc
*.tgz
*.bak
*.tmp

##################################
# Prisma-specific
##################################

# Local SQLite database (common in dev)
prisma/*.db
prisma/*.db-journal

# Prisma migrations (optional — usually you SHOULD commit these)
# prisma/migrations/

# Generated Prisma client (only ignore if you're generating elsewhere, e.g. CI)
# By default, KEEP this committed if using node_modules (standard setup)
# Uncomment if needed:
# prisma/generated/

##################################
# Uploads / temp (optional)
##################################
uploads/
tmp/